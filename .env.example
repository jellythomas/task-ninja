# Task Ninja Configuration
# Copy this to .env and fill in your values.
# This file is auto-generated on first run — you can also configure via the Setup Wizard.

# --- Server ---
# TASK_NINJA_SECRET_HASH and TASK_NINJA_SECRET_SALT are auto-generated on first run.
# To regenerate: python server.py --regenerate-token
TASK_NINJA_HOST=127.0.0.1
TASK_NINJA_PORT=8420
TASK_NINJA_REMOTE_ACCESS=false    # Set true + restart to listen on 0.0.0.0 (for Tailscale/ngrok)

# --- Jira ---
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=                   # Generate: https://id.atlassian.com/manage-profile/security/api-tokens

# --- Bitbucket (optional — for auto PR creation) ---
BITBUCKET_WORKSPACE=              # Your Bitbucket workspace slug
BITBUCKET_USERNAME=               # Your Bitbucket username
BITBUCKET_APP_PASSWORD=           # Generate: https://bitbucket.org/account/settings/app-passwords/

# --- Notifications (optional) ---
NOTIFICATIONS_ENABLED=false
VAPID_PUBLIC_KEY=                 # For Web Push background notifications
VAPID_PRIVATE_KEY=                # Generate VAPID keys: npx web-push generate-vapid-keys
VAPID_EMAIL=                      # Your email for VAPID identification

# --- Scheduler & Watchdog (optional) ---
AUTO_RETRY_ENABLED=false          # Auto-retry failed tickets
AUTO_RETRY_DELAY_MINUTES=15       # Wait time before retry
AUTO_RETRY_MAX=3                  # Max retry attempts per ticket
WORKING_HOURS_ENABLED=false       # Only spawn workers during business hours
WORKING_HOURS_START=09:00
WORKING_HOURS_END=18:00
WORKING_HOURS_DAYS=mon,tue,wed,thu,fri
